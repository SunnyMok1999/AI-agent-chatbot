# Reuse values from root .env where possible
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_VLM_MODEL=meta/llama-3.2-11b-vision-instruct
ENABLE_VLM_PREPROCESS_FOR_AGENTS=true
MAX_VLM_PREPROCESS_CHARS=3000
EVAL_MIN_PDF_TEXT_CHARS_FOR_NATIVE_OCR=180

# Optional per-agent model mapping (leave empty to fallback to NVIDIA_MODEL)
# Suggested free-tier-friendly template (availability depends on your NVIDIA account):
NVIDIA_MODEL_MANAGER=meta/llama-3.1-8b-instruct
NVIDIA_MODEL_NEWTON=meta/llama-3.1-8b-instruct
NVIDIA_MODEL_GAUSS=mistralai/mistral-7b-instruct-v0.3
NVIDIA_MODEL_FEYNMAN=qwen/qwen2.5-7b-instruct
NVIDIA_MODEL_POLYA=meta/llama-3.1-8b-instruct
NVIDIA_MODEL_GRIFFITHS=meta/llama-3.1-8b-instruct
NVIDIA_MODEL_SAKURAI=mistralai/mistral-7b-instruct-v0.3

CHROMA_COLLECTION_NAME=math_documents_local_bge
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

TOP_K_RETRIEVAL=5
ENABLE_TUTOR_MODE=true
ENABLE_HYBRID_RETRIEVAL=true
ENABLE_MATH_RERANKER=true
RETRIEVAL_CANDIDATE_K=16
ENABLE_DOMAIN_METADATA_FILTER=true
ENABLE_CROSS_ENCODER_RERANKER=true
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
ENABLE_MULTI_AGENT_TUTOR=true
MULTI_AGENT_MAX_CONTEXT_CHARS=9000
ENABLE_STRICT_CORRECTNESS_MODE=true
REFUSE_UNCERTAIN_DERIVATIONS=true
MAX_RESPONSE_CHARS=1600
SOURCE_MIN_KEYWORD_OVERLAP=0.08
SOURCE_MAX_SCORE_GAP=2.5
ENABLE_AMBIGUITY_GATE=true
AMBIGUITY_SCORE_THRESHOLD=0.55
PY_BACKEND_PORT=8002
