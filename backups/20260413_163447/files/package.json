{
  "name": "trae-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "client:dev": "sh -c 'for p in 5173 5174 5175 5176 5177 5178 5179; do PIDS=$(lsof -ti :$p); if [ -n \"$PIDS\" ]; then kill -9 $PIDS; fi; done; vite'",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "server:dev": "sh -c 'PIDS=$(lsof -ti :3001); if [ -n \"$PIDS\" ]; then kill -9 $PIDS; fi; nodemon'",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "seed": "tsx scripts/seed.ts",
    "ingest:file": "tsx scripts/ingest-file.ts",
    "ingest:manifest": "tsx scripts/ingest-manifest.ts",
    "ck12:convert": "tsx scripts/ck12-to-md.ts",
    "khan:convert": "tsx scripts/khan-to-md.ts",
    "chroma:inspect": "tsx scripts/chroma-inspect.ts",
    "chroma:reset": "tsx scripts/chroma-reset.ts"
  },
  "dependencies": {
    "@huggingface/inference": "^2.8.1",
    "@langchain/community": "^0.0.53",
    "@langchain/openai": "^0.0.28",
    "@supabase/supabase-js": "^2.43.4",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.6.8",
    "cheerio": "^1.2.0",
    "chromadb": "^1.8.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.21.2",
    "langchain": "^0.1.37",
    "lucide-react": "^0.511.0",
    "mammoth": "^1.7.1",
    "markdown-it": "^14.1.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.3.0",
    "tailwind-merge": "^3.0.2",
    "tesseract.js": "^7.0.0",
    "uuid": "^9.0.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/markdown-it": "^14.1.1",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.15.30",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^9.0.8",
    "@vercel/node": "^5.3.6",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "kill-port": "^2.0.1",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
