# Backend
PORT=3001
NODE_ENV=development

# NVIDIA NIM
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_VLM_MODEL=meta/llama-3.2-11b-vision-instruct

# OpenRouter
OPEN_ROUTER_API_KEY=your_open_router_api_key_here
OPEN_ROUTER_MODEL=meta/llama-3.1-8b-instruct
OPEN_ROUTER_BASE_URL=https://openrouter.ai/api/v1

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ChromaDB
CHROMA_PERSIST_DIRECTORY=./data/chromadb
CHROMA_COLLECTION_NAME=math_documents_local_bge
CHROMA_URL=http://localhost:8001

# Embeddings
EMBEDDING_PROVIDER=local-transformers # openai, huggingface, local-transformers, local
EMBEDDING_MODEL=Xenova/bge-base-en-v1.5
OPENAI_API_KEY=your_openai_api_key
HUGGINGFACE_API_KEY=your_huggingface_api_key_here # For HuggingFaceInferenceEmbeddings
HUGGINGFACE_ENDPOINT_URL=https://router.huggingface.co
EMBEDDING_BATCH_SIZE=20
LOCAL_EMBEDDING_DIM=256

# Upload API policy
ENABLE_PUBLIC_UPLOAD=false

# File Upload
MAX_FILE_SIZE=104857600  # 100MB
UPLOAD_DIRECTORY=./uploads

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=5
MMR_DIVERSITY=0.5
MIN_CONFIDENCE_SCORE=0.7
ENABLE_DIRECT_LLM_FALLBACK=false
ENABLE_SMALLTALK_FALLBACK=true
ENABLE_TUTOR_MODE=true
ENABLE_HYBRID_RETRIEVAL=true
ENABLE_MATH_RERANKER=true
RETRIEVAL_CANDIDATE_K=16
RAG_TIMEOUT_MS=45000
RAG_RETRIEVAL_TIMEOUT_MS=12000
RAG_LLM_TIMEOUT_MS=25000
RAG_MAX_QUESTION_CHARS=1200

# Frontend
VITE_API_URL=http://localhost:8002
VITE_WS_URL=ws://localhost:3001
VITE_ENABLE_DEBUG_CHAT=true
